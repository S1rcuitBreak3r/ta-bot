# Copy this file to .env and fill in values for local development.
# On Railway, set these in the project's Variables tab — do not commit .env.

TELEGRAM_BOT_TOKEN=your_token_here
ANTHROPIC_API_KEY=your_key_here
ADMIN_TELEGRAM_ID=604492237

# Storage root — on Railway this is your volume mount path (e.g. /data).
# Override locally to avoid writing to /data.
STORAGE_ROOT=./local_data

# Derived paths — leave blank to use defaults under STORAGE_ROOT.
# DATABASE_PATH=
# CHROMA_PATH=
# PERSISTENCE_PATH=
